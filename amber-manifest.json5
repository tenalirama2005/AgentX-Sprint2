{
  manifest_version: "0.1.0",
  program: {
    image: "tenalirama2026/agentx-sprint2:v8",
    entrypoint: [
      "/usr/local/bin/python3",
      "/app/scenarios/fwa/purple_agent/fba_agent.py",
      "--host", "0.0.0.0",
      "--port", "9019"
    ],
    env: {
      NEBIUS_API_KEY: "${config.nebius_api_key}",
      NVIDIA_API_KEY: "${config.nvidia_api_key}",            
      OPENAI_API_KEY: "${config.openai_api_key}",
      HF_TOKEN: "${config.hf_token}",
    },
    network: {
      endpoints: [
        { name: "a2a", port: 9019 },
      ],
    },
  },
  config_schema: {
    type: "object",
    properties: {
      nebius_api_key: { type: "string", secret: true },
      nvidia_api_key: { type: "string", secret: true },            
      openai_api_key: { type: "string", secret: true },
      hf_token: { type: "string", secret: true },
    },
    required: ["nvidia_api_key", "openai_api_key", "hf_token"],
    additionalProperties: false,
  },
  provides: {
    a2a: { kind: "a2a", endpoint: "a2a" },
  },
  exports: {
    a2a: "a2a",
  },
}